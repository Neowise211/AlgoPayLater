# Algo Pay — Loan Investigator
# Copy this file to .env and fill in your values.
# NEVER commit .env or any file containing real credentials.

# ---------------------------------------------------------------------------
# Supabase (Vite convention — must be prefixed VITE_ to be exposed to the app)
# ---------------------------------------------------------------------------
# Your project URL — found in: Supabase Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=

# Public anon key — found in: Supabase Dashboard > Settings > API > Project API keys
VITE_SUPABASE_ANON_KEY=

# Set to "true" to run without a Supabase connection (uses mock leaderboard data)
VITE_DEMO_MODE=false
